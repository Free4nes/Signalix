{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": false
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": false
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": false
      },
      "ios": {
        "autoIncrement": false
      }
    },
    "playstore": {
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
