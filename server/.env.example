# Copy to .env and replace values. Environment variables override .env.
# DATABASE_URL: replace Ricardo-Leticia100 with your local PostgreSQL password. For tests use messenger_test DB.
# If password contains @ : / # % etc., use percent-encoding (e.g. @ = %40).
DATABASE_URL=postgres://postgres:rikykitkat100@127.0.0.1:5432/messenger?sslmode=disable
JWT_SECRET=your-secret-key-at-least-32-characters-long
OTP_SALT=your-otp-salt
OTP_DEV_MODE=true
# Required when OTP_DEV_MODE=false (real OTP via Twilio Verify)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
PORT=8080

DEV_AUTOCREATE_USERS=false
